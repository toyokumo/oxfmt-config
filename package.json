{
  "name": "@toyokumo/oxfmt-config",
  "version": "0.1.1",
  "description": "oxfmt rule set for Toyokumo",
  "keywords": [
    "oxfmt"
  ],
  "homepage": "https://github.com/toyokumo/oxfmt-config",
  "license": "Apache-2.0",
  "author": "Toyokumo, Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toyokumo/oxfmt-config.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "format": "oxfmt --write",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "oxfmt": "^0.47.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "oxfmt": ">=0.47.0 <1.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1"
}
